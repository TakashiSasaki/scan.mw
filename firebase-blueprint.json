{
  "entities": {
    "ObjectRecord": {
      "title": "Object Record",
      "description": "Represents a real-world physical object being cataloged.",
      "type": "object",
      "properties": {
        "objectId": {
          "type": "string",
          "description": "The unique ID matching the document ID."
        },
        "name": {
          "description": "Short name of the object.",
          "type": "string"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the object."
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns this object."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "lost",
            "disposed"
          ]
        },
        "currentLocation": {
          "type": "object",
          "description": "Geographical location (latitude/longitude/address).",
          "properties": {
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            },
            "address": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "primaryImageId": {
          "type": "string",
          "description": "ID of the primary image."
        },
        "identifierSummary": {
          "type": "object",
          "description": "Denormalized UI summary.",
          "properties": {
            "activeKinds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "activeIdentifierCount": {
              "type": "number"
            },
            "hasQr": {
              "type": "boolean"
            },
            "hasNfc": {
              "type": "boolean"
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "primaryImageUrl": {
          "type": "string",
          "description": "Denormalized URL for fast list view rendering."
        },
        "legacy": {
          "type": "object",
          "properties": {
            "sourceCollection": {
              "type": "string",
              "enum": [
                "items"
              ]
            },
            "legacyItemId": {
              "type": "string"
            }
          }
        },
        "createdBy": {
          "type": "string"
        },
        "ownerUid": {
          "type": "string"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "link_shared",
            "community_visible",
            "public_readable"
          ]
        },
        "lastReportedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastReportedBy": {
          "type": "string"
        },
        "lastReportedLocation": {
          "type": "object"
        },
        "lastReportedPlaceLabel": {
          "type": "string"
        }
      },
      "required": [
        "objectId",
        "ownerId",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "IdentifierRecord": {
      "title": "Identifier Record",
      "description": "Lookup table from a scanned QR/NFC/manual value to an object.",
      "type": "object",
      "properties": {
        "identifierKey": {
          "type": "string",
          "description": "Normalized Firestore-safe ID."
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns this identifier."
        },
        "objectId": {
          "type": "string",
          "description": "Optional object this identifier resolves to."
        },
        "kind": {
          "type": "string",
          "enum": [
            "qr",
            "nfc",
            "manual",
            "barcode",
            "bluetooth"
          ]
        },
        "scheme": {
          "type": "string",
          "description": "e.g., qr-url-token, nfc-uid"
        },
        "canonicalValue": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "unassigned",
            "retired",
            "lost",
            "replaced"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rawValue": {
          "type": "string",
          "description": "Original raw scanned value."
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable label."
        },
        "firstObservedAt": {
          "type": "string",
          "format": "date-time"
        },
        "firstObservedBy": {
          "type": "string"
        },
        "firstObservationId": {
          "type": "string"
        },
        "lastObservedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastObservedBy": {
          "type": "string"
        },
        "lastObservationId": {
          "type": "string"
        },
        "lastObservedSource": {
          "type": "string"
        },
        "discoveryState": {
          "type": "string",
          "enum": [
            "observed",
            "registered",
            "detached",
            "unknown"
          ]
        },
        "schemaVersion": {
          "type": "number"
        },
        "lastSeenAt": {
          "type": "string",
          "format": "date-time"
        },
        "rawPayload": {
          "type": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "null"
          ],
          "description": "Optional raw JSON payload for non-identifying data in v2 models."
        },
        "identityModelVersion": {
          "type": "number",
          "enum": [
            1,
            2
          ],
          "description": "Runtime interpretation version. 1 (default) or 2."
        },
        "identitySchemaVersion": {
          "type": "number",
          "description": "Schema version of the canonical identity payload. Defaults to 1 for v2."
        },
        "canonicalizationVersion": {
          "type": "number",
          "description": "Version of the JSON canonicalization algorithm. Defaults to 1 for v2."
        }
      },
      "required": [
        "identifierKey",
        "ownerId",
        "kind",
        "scheme",
        "canonicalValue",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "IdentifierObservationRecord": {
      "title": "Identifier Observation Record",
      "description": "An evidence/log record of an identifier observation. Does not represent canonical object state. Can exist before an object is registered. Direct client-created observations are initially limited by Firestore rules to ordinary user sighting/scan records. Order by observedAt or receivedAt.",
      "type": "object",
      "properties": {
        "observationId": {
          "type": "string",
          "description": "Must equal document ID. Use UUIDv7 for client-created, deterministic IDs for imported/synthetic."
        },
        "identifierKey": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "The owner/scope boundary for the observation record. Existing pre-ownerId records may lack this field."
        },
        "observerKind": {
          "type": "string",
          "enum": [
            "user",
            "device",
            "system"
          ],
          "description": "Device is reserved for future backend/device-auth ingestion."
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "enum": [
            "nfc",
            "qr",
            "manual",
            "barcode",
            "ble",
            "camera",
            "gateway",
            "import"
          ],
          "description": "'import' is reserved for future backend/migration flows. 'gateway' and 'ble' are reserved for later device/sensor ingestion unless explicitly enabled by a later phase."
        },
        "observationType": {
          "type": "string",
          "enum": [
            "sighting",
            "scan",
            "proximity",
            "gateway_seen",
            "imported"
          ],
          "description": "'imported' is reserved for future backend/migration flows. 'proximity' and 'gateway_seen' are reserved for later device/sensor ingestion unless explicitly enabled by a later phase."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "objectId": {
          "type": "string",
          "description": "Optional object this observation relates to."
        },
        "observerUid": {
          "type": "string"
        },
        "observerIsAnonymous": {
          "type": "boolean"
        },
        "observerDeviceId": {
          "type": "string"
        },
        "placeLabel": {
          "type": "string"
        },
        "location": {
          "type": "object"
        },
        "note": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "linked_object",
            "community",
            "public"
          ]
        },
        "schemaVersion": {
          "type": "number"
        }
      },
      "required": [
        "observationId",
        "identifierKey",
        "observerKind",
        "observedAt",
        "receivedAt",
        "source",
        "observationType",
        "createdAt"
      ]
    },
    "ObjectIdentifierBindingRecord": {
      "title": "Object Identifier Binding Record",
      "description": "Canonical active relationship state linking an object to an identifier. This is NOT an append-only historical log; use objectEvents for history. Observations do not replace canonical bindings.",
      "type": "object",
      "properties": {
        "bindingId": {
          "type": "string",
          "description": "Deterministic active ID formatted as ${objectId}__${identifierKey}__active to prevent duplicate active bindings"
        },
        "ownerId": {
          "type": "string"
        },
        "objectId": {
          "type": "string"
        },
        "identifierKey": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "detached",
            "replaced"
          ]
        },
        "attachedAt": {
          "type": "string",
          "format": "date-time"
        },
        "attachedBy": {
          "type": "string"
        },
        "detachedAt": {
          "type": "string",
          "format": "date-time"
        },
        "detachedBy": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "bindingId",
        "ownerId",
        "objectId",
        "identifierKey",
        "status",
        "attachedAt",
        "attachedBy",
        "createdAt",
        "updatedAt"
      ]
    },
    "ObjectEventRecord": {
      "title": "Object Event Record",
      "description": "Append-only event log for inventory operations. Remains object operational history, not the generic observation log.",
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "objectId": {
          "type": "string"
        },
        "identifierKey": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "created",
            "updated",
            "scanned",
            "located",
            "image_added",
            "image_removed",
            "identifier_attached",
            "identifier_detached",
            "identifier_replaced",
            "migrated"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "actorUid": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "qr",
            "nfc",
            "manual",
            "camera",
            "system",
            "migration"
          ]
        },
        "location": {
          "type": "object"
        },
        "metadata": {
          "type": "object"
        }
      },
      "required": [
        "eventId",
        "ownerId",
        "type",
        "occurredAt",
        "actorUid"
      ]
    },
    "ObjectImageRecord": {
      "title": "Object Image Record",
